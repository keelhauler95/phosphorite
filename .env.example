# Phosphorite environment template
# Copy to .env (or .env.local) and adjust.

# ----------------------------------------------------------------
# Core port configuration
# ----------------------------------------------------------------
# The backend listens on PHOS_BACKEND_PORT and both clients proxy to it.
# The GM UI runs on PHOS_GM_PORT, the Player UI on PHOS_PLAYER_PORT.
# Every script (npm, Docker, launcher) reads the same values.
PHOS_BACKEND_PORT=3100
PHOS_GM_PORT=5173
PHOS_PLAYER_PORT=5174

# Optional: override the host address used by Docker/Node when binding.
PHOS_BACKEND_HOST=0.0.0.0
PHOS_GM_HOST=0.0.0.0
PHOS_PLAYER_HOST=0.0.0.0

# Optional: if you reverse-proxy to a custom origin, set it here so
# the Vite dev servers know where to forward /api and /socket.io calls.
# Example: PHOS_BACKEND_ORIGIN=https://api.example.com
PHOS_BACKEND_ORIGIN=
